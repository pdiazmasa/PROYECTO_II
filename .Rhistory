# Simulate skewed data
set.seed(123)
# Generate right-skewed data (e.g., exponential distribution)
data_skewed <- rexp(100, rate = 0.1)  # skewed to the right
# Add extreme outliers
data_skewed_extreme <- c(data_skewed, 200, 220, 250)  # very large values
# Combine into a data frame for easier handling
df <- data.frame(value = data_skewed_extreme)
# Calculate z-score for 'medv'
z_scores <- scale(df$value)
# Identify values with |Z| > 3, considered outliers
outliers_z <- which(abs(z_scores) > 3) # índices de outliers
df[outliers_z,]  # detected extreme values
# Boxplot identifies outliers using the interquartile range (IQR)
box_stats <- boxplot.stats(df$value)
outliers_iqr <- box_stats$out # values considered outliers
# Boxplot visualization
boxplot(df$value, main="Boxplot of Skewed Data")
# Histogram
hist(df$value, main="Histogram of Skewed Data", xlab="Value", breaks=20)
df_no_outliers <- df %>% filter(!value %in% outliers_iqr)
# Check number of values removed
cat("Number of outliers removed:", length(outliers_iqr), "\n")
p95 <- quantile(df$value, 0.95)
p95
df$winsor_value <- ifelse(df$value > p95, p95, df$value)
# Boxplot visualization
boxplot(df$winsor_value, main="Boxplot of Winsorizing Data")
hist(df$winsor_value, main="Histogram of Winsorizing Data", xlab="Value", breaks=20)
df$log_value <- log(df$value)
# visualization
boxplot(df$log_value, main="Boxplot of Log-Transformed Data")
hist(df$log_value, main="Histogram of Log-Transformed Data", xlab="Value", breaks=20)
