## Función auxiliar para aplicar WSS con hcut
hcut_wss <- function(x, k, ...) {
if (k == 1) {
list(cluster = rep(1, nrow(x)))}
else {
hcut(
x = x,
k = k,
hc_method = "ward.D2",
hc_metric = "euclidean")}}
p1 <- fviz_nbclust(
x = matriz_clustering,
FUNcluster = hcut,
method = "silhouette",
hc_method = "ward.D2",
k.max = 10,
verbose = FALSE,
diss = dist_distritos) +
labs(title = "Número de clústeres según Silhouette")
p2 <- fviz_nbclust(
