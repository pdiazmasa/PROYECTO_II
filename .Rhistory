## Probability Sampling
### Simple Random Sampling
sample (1:1000, 10) # permite seleccionar aleatoriamente 10 num del 1 al 1000
data("iris")
print(nrow(iris))
iris_small<-iris[sample(1:nrow(iris),nrow(iris)/2),] # cojo la mitad de filas y me quedo con todas las columnas
print(nrow(iris_small))
sample (1:10, 10)
sample (1:10, 10, replace = TRUE)
sample (1:10, 10) # sin repetición
sample (1:10, 10, replace = TRUE) # con posible repetición
set.seed(1)             # semilla, SUPER IMPORTANTE
sample_iris <- iris %>%
group_by(Species) %>% # agrupamos por especie
sample_n(10)          # 10 ejemlos de cada grupo
print(nrow(sample_iris))
