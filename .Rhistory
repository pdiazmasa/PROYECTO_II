knitr::opts_chunk$set(echo = TRUE)
distritos_valencia_base <- read_csv("../../datasets/valencia/distritos_valencia_base_final.csv", show_col_types = FALSE)
distritos_bilbao_base <- read_csv("../../datasets/vizcaya-bilbao/distritos_bilbao_base_final.csv", show_col_types = FALSE)
head(distritos_valencia_base)
dim(distritos_valencia_base)
head(distritos_bilbao_base)
dim(distritos_bilbao_base)
distritos_valencia_clust <- distritos_valencia_base %>%
mutate(ciudad = "Valencia")
distritos_bilbao_clust <- distritos_bilbao_base %>%
mutate(ciudad = "Bilbao")
distritos <- bind_rows(distritos_valencia_clust, distritos_bilbao_clust)
dim(distritos)
table(distritos$ciudad)
datos_clustering <- distritos %>%
select(
indice_envejecimiento,
ratio_colegio,
ratio_hospital,
esfuerzo_alquiler,
ratio_zonas_verdes)
faltantes_clustering <- datos_clustering %>%
summarise(across(everything(), ~ sum(is.na(.)))) %>%
pivot_longer(
cols = everything(),
names_to = "variable",
values_to = "num_faltantes") %>% arrange(desc(num_faltantes))
faltantes_clustering
info_distritos <- distritos %>%
select(
ciudad,
cod_distrito,
nombre_distrito_norm)
filas_completas <- complete.cases(datos_clustering)
datos_clustering_completo <- datos_clustering[filas_completas, ]
info_distritos_completo <- info_distritos[filas_completas, ]
dim(datos_clustering_completo)
dim(info_distritos_completo)
colSums(is.na(datos_clustering_completo))
datos_clustering_scaled <- scale(datos_clustering_completo)
summary(datos_clustering_scaled)
matriz_clustering <- datos_clustering_scaled
dist_distritos <- dist(
matriz_clustering,
method = "euclidean")
dist_distritos
fviz_dist(
dist_distritos,
show_labels = FALSE)
set.seed(123)
hopkins_distritos <- get_clust_tendency(
matriz_clustering,
n = nrow(matriz_clustering) - 1,
graph = TRUE)
hopkins_distritos$hopkins_stat
knitr::opts_chunk$set(echo = TRUE)
set.seed(123)
hopkins_municipios <- get_clust_tendency(
matriz_clustering,
n = nrow(matriz_clustering) - 1,
graph = TRUE)
hopkins_municipios$hopkins_stat
## Función auxiliar para aplicar WSS con hcut
hcut_wss <- function(x, k, ...) {
if (k == 1) {
list(cluster = rep(1, nrow(x)))}
else {
hcut(
x = x,
k = k,
hc_method = "ward.D2",
hc_metric = "euclidean")}}
p1 <- fviz_nbclust(
x = matriz_clustering,
FUNcluster = hcut,
method = "silhouette",
hc_method = "ward.D2",
k.max = 10,
verbose = FALSE,
diss = dist_distritos) +
labs(title = "Número de clústeres según Silhouette")
p2 <- fviz_nbclust(
x = matriz_clustering,
FUNcluster = hcut_wss,
method = "wss",
hc_method = "ward.D2",
k.max = 10,
verbose = FALSE) +
labs(title = "Número de clústeres según WSS")
grid.arrange(p1, p2, nrow = 1)
set.seed(123)
nb_distritos <- NbClust(
data = matriz_clustering,
distance = "euclidean",
min.nc = 2,
max.nc = 10,
method = "ward.D2",
index = "alllong")
fviz_nbclust(nb_distritos) +
labs(title = "Número de clústeres según NbClust")
set.seed(123)
nb_distritos <- NbClust(
data = matriz_clustering,
distance = "euclidean",
min.nc = 2,
max.nc = 10,
method = "ward.D2",
index = "all")
fviz_nbclust(nb_distritos) +
labs(title = "Número de clústeres según NbClust")
set.seed(123)
nb_municipios <- NbClust(
data = matriz_clustering,
distance = "euclidean",
min.nc = 2,
max.nc = 10,
method = "ward.D2",
index = "alllong")
fviz_nbclust(nb_municipios)
