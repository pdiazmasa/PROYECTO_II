misclust <- municipios_cluster$cluster_jerarquico
# PCA sobre la matriz utilizada en el clustering
library(PLSandO)
miPCA <- pca(
matriz_clustering,
scaling = "none"
)
# Gráfico de varianza explicada
pcaPlot(miPCA, type = "scree")
K <- 4
knitr::kable(
miPCA$explVar[1:K, ],
digits = 2,
caption = "Varianza explicada por las primeras componentes principales"
)
p1 <- pcaPlot(
miPCA,
type = "scores",
comp = 1:2,
colBy = data.frame("cluster" = misclust),
labels = FALSE,
repel = TRUE
)
p2 <- pcaPlot(
miPCA,
type = "scores",
comp = 3:4,
colBy = data.frame("cluster" = misclust),
labels = FALSE,
repel = TRUE
)
p3 <- pcaPlot(
miPCA,
type = "corr",
comp = 1:2,
colBy = "contrib",
labels = TRUE,
repel = TRUE,
col = "hot"
)
p4 <- pcaPlot(
miPCA,
type = "corr",
comp = 3:4,
colBy = "contrib",
labels = TRUE,
repel = TRUE,
col = "hot"
)
p1
p2
p3
p4
