tablaNA[tablaNA$numNA > 0,]
modelosCoches3 = modelosCoches2
mm = model.matrix(~ 0 + Drive, data = modelosCoches3)
head(mm)
X_num = modelosCoches3[, sapply(modelosCoches3, is.numeric)]
X_total = cbind(X_num, mm)
dim(X_total)
ttt = table(modelosCoches3$Make); ttt  # tabla de frecuencias
umbral = 1
barplot(ttt, las = 2, cex.names = 0.7)
abline(h = umbral, lty = 2)  # línea de referencia del umbral
agrupar = names(ttt)[which(ttt < umbral)]
sum(modelosCoches3$Make %in% agrupar)
modelosCoches3$Make[modelosCoches3$Make %in% agrupar] = "Others"
ttt = table(modelosCoches3$Make)
barplot(ttt, las = 2, cex.names = 0.7)
plot(density(modelosCoches3$HighPrice),
main = "Variable original",
col = "red3", lwd = 2,
xlab = "HighPrice")
modelosCoches3$HighPrice_log = log2(modelosCoches3$HighPrice)
plot(density(modelosCoches3$HighPrice_log),
main = "Variable transformada (log2)",
col = "red3", lwd = 2,
xlab = "HighPrice")
ccc = modelosCoches3$HighPrice
hist(ccc, xlab = "HighPrice")
perce = round(quantile(ccc, probs = c(0, 0.3, 0.7, 1)), 2)  # 30%, 40%, 30%
precioCat = cut(ccc,
breaks = perce,
labels = c("Low", "Medium", "High"),
include.lowest = TRUE)
table(precioCat, useNA = "a")
aaa = aggregate(modelosCoches3$HighPrice,
by = list(precioCat),
range)
aaa
ttt = table(modelosCoches3$Make)
barplot(ttt, las = 2, cex.names = 0.7)
ttt = table(modelosCoches3$Make); ttt  # tabla de frecuencias
umbral = 2
barplot(ttt, las = 2, cex.names = 0.7)
abline(h = umbral, lty = 2)  # línea de referencia del umbral
agrupar = names(ttt)[which(ttt < umbral)]
sum(modelosCoches3$Make %in% agrupar)
