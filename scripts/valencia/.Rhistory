vars_clustering <- c("HighPrice", "CityMPG", "HwyMPG", "Seating",
"Acc060", "QtrMile", "Braking", "FuelCap",
"Length", "Width", "Height", "Wheelbase",
"UTurn", "Weight")
coches_clust <- modelosCoches2[, vars_clustering]
data.frame(
variable = names(coches_clust),
tipo = sapply(coches_clust, class),
na = colSums(is.na(coches_clust))
)
data.frame(variable = names(coches_clust),
tipo = sapply(coches_clust, class),
na = colSums(is.na(coches_clust)))
# Librerías necesarias
library(cluster)
library(factoextra)
# Escalado de los datos
coches_clust_scaled <- scale(coches_clust, center = TRUE, scale = TRUE)
# Cálculo de la matriz de distancias euclídeas
dist_matrix <- dist(coches_clust_scaled, method = "euclidean")
# Test de Hopkins (implementación manual compatible)
set.seed(123)
n <- nrow(coches_clust_scaled)
m <- floor(0.1 * n)
# Selección aleatoria de puntos reales
indices <- sample(1:n, m)
# Generación de puntos aleatorios en el rango de los datos
random_points <- apply(coches_clust_scaled, 2, function(x) runif(m, min(x), max(x)))
# Distancias de puntos reales a su vecino más cercano
real_dist <- sapply(indices, function(i) {
min(dist(rbind(coches_clust_scaled[i, ], coches_clust_scaled[-i, ]))[1:(n-1)])
})
# Distancias de puntos aleatorios a datos reales
rand_dist <- sapply(1:m, function(i) {
min(sqrt(rowSums((t(t(coches_clust_scaled) - random_points[i, ]))^2)))
})
# Estadístico de Hopkins
hopkins_stat <- sum(rand_dist) / (sum(rand_dist) + sum(real_dist))
hopkins_stat
# Librerías necesarias
library(cluster)
library(factoextra)
library(gridExtra) #Gráficos
# Escalado de los datos
coches_clust_scaled <- scale(coches_clust, center = TRUE, scale = TRUE)
# Cálculo de la matriz de distancias euclídeas
dist_matrix <- dist(coches_clust_scaled, method = "euclidean")
# Test de Hopkins (implementación manual compatible)
set.seed(123)
n <- nrow(coches_clust_scaled)
m <- floor(0.1 * n)
# Selección aleatoria de puntos reales
indices <- sample(1:n, m)
# Generación de puntos aleatorios en el rango de los datos
random_points <- apply(coches_clust_scaled, 2, function(x) runif(m, min(x), max(x)))
# Distancias de puntos reales a su vecino más cercano
real_dist <- sapply(indices, function(i) {
min(dist(rbind(coches_clust_scaled[i, ], coches_clust_scaled[-i, ]))[1:(n-1)])
})
# Distancias de puntos aleatorios a datos reales
rand_dist <- sapply(1:m, function(i) {
min(sqrt(rowSums((t(t(coches_clust_scaled) - random_points[i, ]))^2)))
})
# Estadístico de Hopkins
hopkins_stat <- sum(rand_dist) / (sum(rand_dist) + sum(real_dist))
hopkins_stat
# Gráfico método del codo (WSS)
p1 <- fviz_nbclust(
x = coches_clust_scaled,
FUNcluster = hcut,
method = "wss",
hc_method = "ward.D2"
) + ggtitle("Método del codo")
# Gráfico método de la silueta
p2 <- fviz_nbclust(
x = coches_clust_scaled,
FUNcluster = hcut,
method = "silhouette",
hc_method = "ward.D2"
) + ggtitle("Método de la silueta")
# Mostrar ambos gráficos juntos
grid.arrange(p1, p2, ncol = 2)
vars_clustering <- c("HighPrice", "CityMPG", "HwyMPG", "Seating", "Acc060", "QtrMile", "Braking", "FuelCap", "Length", "Width", "Height", "Wheelbase", "UTurn", "Weight")
coches_clust <- modelosCoches2[, vars_clustering]
data.frame(variable = names(coches_clust), tipo = sapply(coches_clust, class), na = colSums(is.na(coches_clust)))
data.frame(variable = names(coches_clust), tipo = sapply(coches_clust, class), na = colSums(is.na(coches_clust)))
# Gráfico método del codo (WSS)
p1 <- fviz_nbclust(x = coches_clust_scaled, FUNcluster = hcut, method = "wss", hc_method = "ward.D2") + ggtitle("Método del codo")
# Gráfico método de la silueta
p2 <- fviz_nbclust(x = coches_clust_scaled,FUNcluster = hcut,method = "silhouette",hc_method = "ward.D2") + ggtitle("Método de la silueta")
# Mostrar ambos gráficos juntos
grid.arrange(p1, p2, ncol = 2)
# Clustering jerárquico (Ward)
hc <- hclust(dist_matrix, method = "ward.D2")
cluster_jerarquico <- cutree(hc, k = 2)
# k-means
set.seed(123)
kmeans_res <- kmeans(coches_clust_scaled, centers = 2, nstart = 25)
cluster_kmeans <- kmeans_res$cluster
# PAM
pam_res <- pam(coches_clust_scaled, k = 2)
cluster_pam <- pam_res$clustering
# Jerárquico vs PAM
table(cluster_jerarquico, cluster_pam)
# k-means vs PAM
table(cluster_kmeans, cluster_pam)
# Jerárquico vs k-means
table(cluster_jerarquico, cluster_kmeans)
library(aricode)
install.packages("aricode")
library(aricode)
ARI(cluster_jerarquico, cluster_pam)
ARI(cluster_kmeans, cluster_pam)
ARI(cluster_jerarquico, cluster_kmeans)
# Jerárquico vs PAM
table(cluster_jerarquico, cluster_pam)
# k-means vs PAM
table(cluster_kmeans, cluster_pam)
# Jerárquico vs k-means
table(cluster_jerarquico, cluster_kmeans)
