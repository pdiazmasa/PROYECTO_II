"Tipo de tracción",
"Tamaño del vehículo",
"Precio alto del vehículo",
"Consumo urbano (millas por galón)",
"Consumo en carretera (millas por galón)",
"Número de plazas",
"Aceleración de 0 a 60 mph",
"Tiempo en cuarto de milla",
"Distancia de frenado",
"Capacidad del depósito",
"Longitud del vehículo",
"Anchura del vehículo",
"Altura del vehículo",
"Distancia entre ejes",
"Diámetro de giro",
"Peso del vehículo"
),
Tipo = c(
