boxplot(modelosCoches2$CityMPG, xlab = "CityMPG")
par(mfrow = c(1,2))
hist(modelosCoches2$Weight, 50)
boxplot(modelosCoches2$Weight, xlab = "Weight")
numNA = apply(modelosCoches2, 2, function(x) sum(is.na(x)))
percNA = round(100*apply(modelosCoches2, 2, function(x) mean(is.na(x))), 2)
