TRUE ~ nombre_join
)
)
mapa_viz <- mapa_viz_raw %>%
left_join(df_viz_limpio, by = "nombre_join")
# Chunk 3: config
# =====================================================================
# VARIABLES — etiquetas legibles para el selector
# =====================================================================
variables_municipios <- c(
# Demografía
"Población total (hab.)"                   = "pob_total",
"% Población extranjera"                   = "pct_extranjeros",
"Índice de envejecimiento (>65 / <16)"     = "indice_envejecimiento",
"Población menor de 16 años"               = "pob_menor_16",
"Población mayor de 65 años"               = "pob_mayor_65",
# Educación
"% Población con estudios superiores"      = "pct_estudios_sup",
"Nº de colegios"                           = "num_colegios",
"Ratio colegios / 1.000 hab."              = "ratio_colegios",
"Distancia al colegio más cercano (km)"    = "distancia_centro_educativo",
# Sanidad
"Nº de centros de salud (AP)"              = "num_centros_salud",
"Ratio centros salud / 1.000 hab."         = "ratio_centros_salud",
"Nº de hospitales"                         = "num_hospitales",
"Ratio hospitales / 1.000 hab."            = "ratio_hospital",
"Distancia al hospital más cercano (km)"   = "distancia_hospital",
# Economía
"Precio alquiler (€/m²)"                   = "precio_m2_alquiler",
"Renta media del hogar (€)"                = "renta_media_hogar",
"Esfuerzo inmobiliario (% renta en alq.)"  = "esfuerzo_alquiler",
"Total contratos laborales"                = "contratos_total",
"% Contratos en agricultura"               = "pct_contratos_agricultura",
"% Contratos en industria"                 = "pct_contratos_industria",
"% Contratos en construcción"              = "pct_contratos_construccion",
"% Contratos en servicios"                 = "pct_contratos_servicios",
# Conectividad
"% Hogares con fibra ≥100 Mbps"            = "pct_hogares_100mbps"
)
# Variables donde más = peor → paleta invertida (verde = bueno, rojo = malo)
vars_invertidas <- c(
"distancia_hospital", "distancia_centro_educativo",
"esfuerzo_alquiler", "indice_envejecimiento"
)
# =====================================================================
# FUNCIÓN: mapa coroplético genérico
# =====================================================================
hacer_mapa <- function(mapa_sf, variable, etiqueta, col_label) {
valores <- mapa_sf[[variable]]
if (is.null(valores) || all(is.na(valores))) {
return(
leaflet() %>%
addProviderTiles(providers$CartoDB.Positron) %>%
addControl(
html     = "<b style='color:#c0392b'>Sin datos para esta variable</b>",
position = "topright"
)
)
}
pal <- if (variable %in% vars_invertidas) {
colorNumeric("RdYlGn", domain = valores, na.color = "#d0d0d0", reverse = TRUE)
} else {
colorNumeric("YlOrRd", domain = valores, na.color = "#d0d0d0")
}
etiquetas_hover <- paste0(
"<b>", mapa_sf[[col_label]], "</b><br>",
etiqueta, ": ",
ifelse(is.na(valores), "Sin dato", round(valores, 2))
) %>% lapply(htmltools::HTML)
leaflet(mapa_sf) %>%
addProviderTiles(providers$CartoDB.Positron) %>%
addPolygons(
fillColor        = ~pal(get(variable)),
color            = "white",
weight           = 1,
opacity          = 1,
fillOpacity      = 0.78,
highlightOptions = highlightOptions(
weight       = 2.5,
color        = "#333",
fillOpacity  = 1,
bringToFront = TRUE
),
label = etiquetas_hover
) %>%
addLegend(
pal      = pal,
values   = ~get(variable),
opacity  = 0.85,
title    = etiqueta,
position = "bottomright"
)
}
# Chunk 4: app
# =====================================================================
# UI
# =====================================================================
ui <- navbarPage(
title = "📊 Ciudad vs Pueblo",
theme = bs_theme(bootswatch = "flatly", primary = "#2c3e50"),
# ------------------------------------------------------------------
# PESTAÑA 1 — Comparativa de ciudades (pendiente)
# ------------------------------------------------------------------
tabPanel(
"🏙️ Comparativa de ciudades",
fluidPage(
br(),
div(
style = "text-align:center; padding:80px 40px;
background:#f8f9fa; border-radius:12px; margin:20px;",
h2("Valencia vs. Bilbao", style = "color:#2c3e50;"),
p("Comparativa a nivel de distrito entre las dos capitales.",
style = "color:#7f8c8d; font-size:16px;"),
tags$span(
"🚧 Sección en desarrollo",
style = "background:#e67e22; color:white; padding:6px 14px;
border-radius:20px; font-size:14px; font-weight:bold;"
)
)
)
),
# ------------------------------------------------------------------
# PESTAÑA 2 — Comparativa de provincias (pendiente)
# ------------------------------------------------------------------
tabPanel(
"🗺️ Comparativa de provincias",
fluidPage(
br(),
div(
style = "text-align:center; padding:80px 40px;
background:#f8f9fa; border-radius:12px; margin:20px;",
h2("Provincia de Valencia vs. Vizcaya", style = "color:#2c3e50;"),
p("Análisis comparativo de los indicadores provinciales.",
style = "color:#7f8c8d; font-size:16px;"),
tags$span(
"🚧 Sección en desarrollo",
style = "background:#e67e22; color:white; padding:6px 14px;
border-radius:20px; font-size:14px; font-weight:bold;"
)
)
)
),
# ------------------------------------------------------------------
# PESTAÑA 3 — Estudio de municipios: Valencia
# ------------------------------------------------------------------
tabPanel(
"🍊 Municipios: Valencia",
sidebarLayout(
sidebarPanel(
width = 3,
h4("Variable a visualizar"),
selectInput(
inputId  = "var_vlc",
label    = NULL,
choices  = variables_municipios,
selected = "distancia_hospital"
),
hr(),
p(style = "font-size:12px; color:#7f8c8d;",
"🟢→🔴 Invertida: menor valor = mejor situación.", br(),
"🟡→🔴 Directa: mayor valor = más intensidad.", br(), br(),
"Pasa el ratón por un municipio para ver el valor exacto.")
),
mainPanel(
width = 9,
h3(textOutput("titulo_vlc")),
leafletOutput("mapa_vlc", height = "640px")
)
)
),
# ------------------------------------------------------------------
# PESTAÑA 4 — Estudio de municipios: Vizcaya
# ------------------------------------------------------------------
tabPanel(
"🌲 Municipios: Vizcaya",
sidebarLayout(
sidebarPanel(
width = 3,
h4("Variable a visualizar"),
selectInput(
inputId  = "var_viz",
label    = NULL,
choices  = variables_municipios,
selected = "distancia_hospital"
),
hr(),
p(style = "font-size:12px; color:#7f8c8d;",
"🟢→🔴 Invertida: menor valor = mejor situación.", br(),
"🟡→🔴 Directa: mayor valor = más intensidad.", br(), br(),
"Pasa el ratón por un municipio para ver el valor exacto.")
),
mainPanel(
width = 9,
h3(textOutput("titulo_viz")),
leafletOutput("mapa_viz", height = "640px")
)
)
)
)
# =====================================================================
# SERVER
# =====================================================================
server <- function(input, output, session) {
# --- Pestaña 3: Valencia ---
output$titulo_vlc <- renderText({
names(variables_municipios)[variables_municipios == input$var_vlc]
})
output$mapa_vlc <- renderLeaflet({
hacer_mapa(
mapa_sf   = mapa_vlc,
variable  = input$var_vlc,
etiqueta  = names(variables_municipios)[variables_municipios == input$var_vlc],
col_label = "NOMBRE"
)
})
# --- Pestaña 4: Vizcaya ---
output$titulo_viz <- renderText({
names(variables_municipios)[variables_municipios == input$var_viz]
})
output$mapa_viz <- renderLeaflet({
hacer_mapa(
mapa_sf   = mapa_viz,
variable  = input$var_viz,
etiqueta  = names(variables_municipios)[variables_municipios == input$var_viz],
col_label = "NOMBRE_TOP"
)
})
}
# =====================================================================
# LANZAR APP
# =====================================================================
shinyApp(ui, server)
knitr::opts_chunk$set(echo = FALSE, message = FALSE, warning = FALSE)
library(shiny)
library(leaflet)
library(plotly)
library(dplyr)
library(sf)
library(stringr)
library(bslib)
# =====================================================================
# CARGA DE DATOS — ajusta las rutas a tu estructura de carpetas
# =====================================================================
# --- Datasets numéricos ---
df_vlc <- read.csv("../../datasets/valencia/municipios_valencia_todos_municipios.csv",
colClasses = c(cod_municipio = "character"))
df_viz <- read.csv("../../datasets/vizcaya-bilbao/municipios_vizcaya_todos_municipios.csv",
colClasses = c(cod_municipio = "character"))
# --- Geometrías ---
# Valencia: GeoJSON filtrado solo provincia 46
mapa_vlc_raw <- st_read(
"../../bases_de_datos/delimitaciones/delimitacion_municipios_valencia.geojson",
quiet = TRUE
) %>%
filter(CODPROV == "46") %>%
mutate(MUNIINE = as.character(MUNIINE)) %>%
st_transform(4326)
# Vizcaya: Shapefile filtrado por TERRITORIO
mapa_viz_raw <- st_read(
"../../bases_de_datos/delimitaciones/MUNICIPIOS_5000_ETRS89.shp",
quiet = TRUE
) %>%
filter(TERRITORIO == "BIZKAIA") %>%
mutate(nombre_join = tolower(str_trim(NOMBRE_TOP))) %>%
st_transform(4326)
# --- Joins mapa + datos ---
# Valencia: join por código INE (robusto, sin problemas de tildes)
mapa_vlc <- mapa_vlc_raw %>%
left_join(
df_vlc %>% mutate(cod_municipio = as.character(cod_municipio)),
by = c("MUNIINE" = "cod_municipio")
)
# Vizcaya: join por nombre normalizado
df_viz_limpio <- df_viz %>%
mutate(
nombre_join = tolower(str_trim(nombre_municipio)),
nombre_join = case_when(
str_detect(nombre_join, "karrantza")    ~ "karrantza harana / valle de carranza",
str_detect(nombre_join, "urduña")       ~ "urduña / orduña",
str_detect(nombre_join, "arrankudiaga") ~ "arrankudiaga-zollo",
str_detect(nombre_join, "munitibar")    ~ "munitibar-arbatzegi gerrikaitz-",
str_detect(nombre_join, "limitado")     ~ "limitadua / el limitado",
TRUE ~ nombre_join
)
)
mapa_viz <- mapa_viz_raw %>%
left_join(df_viz_limpio, by = "nombre_join")
# =====================================================================
# VARIABLES — etiquetas legibles para el selector
# =====================================================================
